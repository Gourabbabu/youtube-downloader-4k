---
---

<div class="w-full flex flex-col relative">

  <!-- Hero Section -->
  <div class="w-full max-w-4xl mx-auto text-center mt-8 lg:mt-16 mb-12">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-zinc-200 to-zinc-400 mb-6 drop-shadow-sm">
      Supercharge Your Media
    </h1>
    <p class="text-zinc-400 text-lg md:text-xl mb-10 max-w-2xl mx-auto font-medium">
      Download high-quality videos and audio instantly. No limits, pure speed.
    </p>

    <!-- Main Input -->
    <form id="dl-form" class="relative group max-w-3xl mx-auto w-full z-20">
      <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-[20px] blur opacity-25 group-hover:opacity-40 transition duration-500"></div>
      <div class="relative flex items-center bg-zinc-900/80 backdrop-blur-xl border border-white/10 rounded-[16px] overflow-hidden shadow-2xl transition-all p-2 focus-within:border-indigo-500/50 focus-within:bg-zinc-900">
        <div class="pl-4 pr-3 text-zinc-400">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
        </div>
        <input 
          id="url-input" 
          type="url" 
          placeholder="Paste YouTube URL..." 
          class="w-full bg-transparent text-zinc-100 text-lg md:text-xl placeholder-zinc-500 py-3 outline-none font-medium" 
          required 
        />
        <button 
          id="fetch-btn" 
          type="submit" 
          class="ml-2 bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-400 hover:to-purple-500 text-white px-6 md:px-8 py-3.5 rounded-[12px] font-bold shadow-lg transform transition-all active:scale-[0.98] flex items-center justify-center min-w-[140px]"
        >
          <span id="fetch-text">Get Video</span>
          <svg id="fetch-spinner" class="animate-spin h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </div>
    </form>
    
    <div id="error-message" class="hidden mt-6 bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-[12px] text-sm max-w-3xl mx-auto font-medium"></div>
  </div>

  <!-- Preview & Download Section -->
  <div id="preview-section" class="hidden w-full max-w-6xl mx-auto animate-[fadeIn_0.5s_ease-out]">
    <div class="flex flex-col xl:flex-row gap-8">
      
      <!-- Video Card -->
      <div class="xl:w-[400px] flex-shrink-0">
        <div class="glass-card rounded-[20px] p-4 flex flex-col gap-4">
          <div class="relative w-full aspect-video rounded-[12px] overflow-hidden bg-black shadow-inner">
            <img id="video-thumb" class="w-full h-full object-cover opacity-90 transition-opacity hover:opacity-100" src="" alt="Video Thumbnail">
            <div id="video-duration" class="absolute bottom-2 right-2 bg-zinc-900/90 backdrop-blur-sm text-white text-xs font-semibold px-2 py-1 rounded-md border border-white/10"></div>
          </div>
          <div class="flex flex-col px-1">
            <h2 id="video-title" class="text-lg font-bold text-zinc-100 leading-snug line-clamp-2"></h2>
            <div class="flex items-center gap-3 mt-4">
              <div class="w-10 h-10 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-400 font-bold border border-indigo-500/30">YT</div>
              <div class="flex flex-col">
                <span id="video-channel" class="text-zinc-200 font-semibold text-sm">YouTube Channel</span>
                <span id="video-views" class="text-zinc-500 text-xs">1M+ views</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Downloads Area -->
      <div class="flex-1 flex flex-col gap-6">
        <!-- Video Formats Table -->
        <div class="glass-card rounded-[20px] overflow-hidden flex flex-col">
          <div class="px-6 py-4 border-b border-white/5 bg-white/[0.02]">
            <h3 class="text-lg font-bold text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
              Video Downloads
            </h3>
          </div>
          <div class="p-0 overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="text-zinc-400 text-xs uppercase tracking-wider bg-white/[0.01]">
                  <th class="px-6 py-3 font-medium">Quality</th>
                  <th class="px-6 py-3 font-medium">Format</th>
                  <th class="px-6 py-3 font-medium text-right">Action</th>
                </tr>
              </thead>
              <tbody class="text-sm divide-y divide-white/5">
                <tr class="hover:bg-white/[0.02] transition-colors group">
                  <td class="px-6 py-4 font-bold text-white flex items-center gap-2">
                    <span class="bg-indigo-500/20 text-indigo-400 px-2 py-0.5 rounded text-[10px] uppercase font-black tracking-wide border border-indigo-500/30">4K</span>
                    2160p
                  </td>
                  <td class="px-6 py-4 text-zinc-400 font-medium">MP4</td>
                  <td class="px-6 py-4 text-right">
                    <button class="dl-action-btn bg-white/5 hover:bg-indigo-500 hover:text-white border border-white/10 hover:border-indigo-500 transition-all px-4 py-2 rounded-lg font-semibold text-zinc-300 text-xs inline-flex items-center gap-2 shadow-sm" data-res="2160" data-type="mp4">
                      Download
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    </button>
                  </td>
                </tr>
                <tr class="hover:bg-white/[0.02] transition-colors group">
                  <td class="px-6 py-4 font-bold text-white flex items-center gap-2">
                    <span class="bg-zinc-700 text-zinc-300 px-2 py-0.5 rounded text-[10px] uppercase font-black tracking-wide border border-white/10">HD</span>
                    1080p
                  </td>
                  <td class="px-6 py-4 text-zinc-400 font-medium">MP4</td>
                  <td class="px-6 py-4 text-right">
                    <button class="dl-action-btn bg-white/5 hover:bg-indigo-500 hover:text-white border border-white/10 hover:border-indigo-500 transition-all px-4 py-2 rounded-lg font-semibold text-zinc-300 text-xs inline-flex items-center gap-2 shadow-sm" data-res="1080" data-type="mp4">
                      Download
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    </button>
                  </td>
                </tr>
                <tr class="hover:bg-white/[0.02] transition-colors group">
                  <td class="px-6 py-4 font-semibold text-zinc-200">720p</td>
                  <td class="px-6 py-4 text-zinc-400 font-medium">MP4</td>
                  <td class="px-6 py-4 text-right">
                    <button class="dl-action-btn bg-white/5 hover:bg-indigo-500 hover:text-white border border-white/10 hover:border-indigo-500 transition-all px-4 py-2 rounded-lg font-semibold text-zinc-300 text-xs inline-flex items-center gap-2 shadow-sm" data-res="720" data-type="mp4">
                      Download
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    </button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Audio Formats Cards -->
        <div class="glass-card rounded-[20px] overflow-hidden flex flex-col">
          <div class="px-6 py-4 border-b border-white/5 bg-white/[0.02]">
            <h3 class="text-lg font-bold text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
              Audio Downloads
            </h3>
          </div>
          <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
            
            <div class="bg-white/[0.03] border border-white/10 hover:border-purple-500/50 rounded-[16px] p-4 flex items-center justify-between transition-all group">
              <div class="flex flex-col">
                <span class="font-bold text-zinc-100">Audio (HQ)</span>
                <span class="text-xs text-zinc-400 font-medium">MP3 • High Quality</span>
              </div>
              <button class="dl-action-btn w-10 h-10 rounded-full bg-white/10 group-hover:bg-purple-500 flex items-center justify-center text-white transition-all shadow-sm" data-res="1080" data-type="mp3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              </button>
            </div>

            <div class="bg-white/[0.03] border border-white/10 hover:border-purple-500/50 rounded-[16px] p-4 flex items-center justify-between transition-all group">
              <div class="flex flex-col">
                <span class="font-bold text-zinc-100">Audio (Standard)</span>
                <span class="text-xs text-zinc-400 font-medium">MP3 • 128kbps</span>
              </div>
              <button class="dl-action-btn w-10 h-10 rounded-full bg-white/10 group-hover:bg-purple-500 flex items-center justify-center text-white transition-all shadow-sm" data-res="1080" data-type="mp3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              </button>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Progress Modal (Overlay) -->
<div id="progress-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300">
  <div class="glass-card w-full max-w-md mx-4 rounded-[24px] p-8 flex flex-col items-center text-center transform scale-95 transition-transform duration-300" id="progress-modal-content">
    <div class="w-16 h-16 rounded-full bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center mb-6">
      <svg class="w-8 h-8 text-indigo-400 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
    </div>
    <h3 class="text-xl font-bold text-white mb-2">Preparing Download</h3>
    <p class="text-zinc-400 text-sm mb-6">Connecting to media servers securely...</p>
    
    <div class="w-full bg-white/10 rounded-full h-2 mb-4 overflow-hidden">
      <div class="bg-gradient-to-r from-indigo-500 to-purple-500 h-2 rounded-full w-2/3 animate-[pulse_1.5s_ease-in-out_infinite]"></div>
    </div>
    
    <div class="flex items-center justify-between w-full text-xs text-zinc-500 font-medium mb-8">
      <span>Initializing</span>
      <span>ETA: calculating...</span>
    </div>

    <button id="cancel-dl-btn" class="px-6 py-2.5 rounded-full bg-white/5 hover:bg-white/10 text-white font-medium text-sm transition-colors border border-white/10 w-full">
      Cancel
    </button>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const form = document.getElementById('dl-form') as HTMLFormElement;
  const urlInput = document.getElementById('url-input') as HTMLInputElement;
  const fetchBtn = document.getElementById('fetch-btn') as HTMLButtonElement;
  const fetchText = document.getElementById('fetch-text');
  const fetchSpinner = document.getElementById('fetch-spinner');
  
  const errorMsg = document.getElementById('error-message');
  const previewCard = document.getElementById('preview-section');
  
  const videoThumb = document.getElementById('video-thumb') as HTMLImageElement;
  const videoTitle = document.getElementById('video-title');
  const videoDuration = document.getElementById('video-duration');
  
  const modal = document.getElementById('progress-modal');
  const modalContent = document.getElementById('progress-modal-content');
  const cancelBtn = document.getElementById('cancel-dl-btn');

  let currentVideoUrl = '';

  const setLoading = (isLoading: boolean) => {
    fetchBtn.disabled = isLoading;
    urlInput.disabled = isLoading;
    if (isLoading) {
      fetchText?.classList.add('hidden');
      fetchSpinner?.classList.remove('hidden');
    } else {
      fetchText?.classList.remove('hidden');
      fetchSpinner?.classList.add('hidden');
    }
  };

  const showError = (msg: string) => {
    if (errorMsg) {
      errorMsg.textContent = msg;
      errorMsg.classList.remove('hidden');
    }
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const url = urlInput.value.trim();
    if (!url) return;

    errorMsg?.classList.add('hidden');
    setLoading(true);
    previewCard?.classList.add('hidden');

    try {
      const res = await fetch('/api/info', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url })
      });
      const data = await res.json();

      if (!res.ok) throw new Error(data.error || 'Failed to fetch video info');
      
      // Update UI
      currentVideoUrl = url;
      if (videoThumb) videoThumb.src = data.thumbnail;
      if (videoTitle) videoTitle.textContent = data.title;
      if (videoDuration) videoDuration.textContent = '10:00+'; // Mocked
      
      previewCard?.classList.remove('hidden');
    } catch (err: any) {
      showError(err.message);
    } finally {
      setLoading(false);
    }
  });

  // Handle Download Buttons
  document.querySelectorAll('.dl-action-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const res = target.dataset.res || '1080';
      const type = target.dataset.type || 'mp4';
      
      // Show Progress Modal
      modal?.classList.remove('hidden');
      setTimeout(() => {
        modal?.classList.remove('opacity-0');
        modalContent?.classList.remove('scale-95');
      }, 10);

      // Trigger Download Redirect
      setTimeout(() => {
        const title = "download";
        const url = encodeURIComponent(currentVideoUrl);
        window.location.href = `/api/download?url=${url}&type=${type}&res=${res}&title=${title}`;
        
        // Hide Modal after redirect triggers
        setTimeout(() => {
          modal?.classList.add('opacity-0');
          modalContent?.classList.add('scale-95');
          setTimeout(() => modal?.classList.add('hidden'), 300);
        }, 2000);
      }, 800);
    });
  });

  // Cancel Button handling
  cancelBtn?.addEventListener('click', () => {
    modal?.classList.add('opacity-0');
    modalContent?.classList.add('scale-95');
    setTimeout(() => modal?.classList.add('hidden'), 300);
  });
</script>
