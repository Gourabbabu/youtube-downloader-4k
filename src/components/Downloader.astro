---
---

<div class="w-full flex flex-col items-center">
  <!-- Search Bar mimicking YouTube's header search -->
  <form id="dl-form" class="w-full max-w-3xl mx-auto mb-6 relative flex shadow-sm">
    <div class="flex w-full items-center">
      <div class="flex-1 border border-[#303030] bg-[#121212] rounded-l-full px-6 py-3 md:py-4 focus-within:border-[#1c62b9] flex items-center shadow-inner transition-colors">
        <svg class="w-5 h-5 text-[#aaaaaa] mr-3 hidden md:block" fill="currentColor" viewBox="0 0 24 24"><path d="M20.87,20.17l-5.59-5.59C16.35,13.35,17,11.75,17,10c0-3.87-3.13-7-7-7s-7,3.13-7,7s3.13,7,7,7c1.75,0,3.35-0.65,4.58-1.71 l5.59,5.59L20.87,20.17z M10,16c-3.31,0-6-2.69-6-6s2.69-6,6-6s6,2.69,6,6S13.31,16,10,16z"/></svg>
        <input 
          id="url-input" 
          type="url" 
          placeholder="Search or paste YouTube link" 
          class="bg-transparent w-full focus:outline-none text-[#f1f1f1] text-lg md:text-xl placeholder-[#aaaaaa]" 
          required 
        />
      </div>
      <button 
        id="fetch-btn" 
        type="submit" 
        class="bg-[#222222] border border-l-0 border-[#303030] hover:bg-[#303030] px-6 md:px-8 py-3 md:py-4 rounded-r-full transition-colors flex items-center justify-center group"
      >
        <svg id="fetch-icon" class="w-6 h-6 text-[#f1f1f1]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.87,20.17l-5.59-5.59C16.35,13.35,17,11.75,17,10c0-3.87-3.13-7-7-7s-7,3.13-7,7s3.13,7,7,7c1.75,0,3.35-0.65,4.58-1.71 l5.59,5.59L20.87,20.17z M10,16c-3.31,0-6-2.69-6-6s2.69-6,6-6s6,2.69,6,6S13.31,16,10,16z"/></svg>
        <svg id="fetch-spinner" class="animate-spin h-6 w-6 text-[#f1f1f1] hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </button>
    </div>
  </form>

  <div id="error-message" class="hidden p-4 rounded-xl bg-red-900/30 text-red-400 border border-red-800/50 text-sm font-medium w-full max-w-3xl mb-4 mx-auto"></div>

  <!-- Video Preview mimicking YouTube Watch Page -->
  <div id="preview-card" class="hidden w-full max-w-6xl mx-auto flex flex-col xl:flex-row gap-6 mt-4 pb-20">
    <div class="flex-1">
      <!-- Video Player Area -->
      <div class="w-full aspect-video bg-black rounded-xl overflow-hidden relative group shadow-lg">
        <img id="video-thumb" class="w-full h-full object-cover" src="" alt="Thumbnail">
        <!-- Play button overlay -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
           <div class="w-16 h-12 bg-black/80 rounded-xl flex items-center justify-center group-hover:bg-[#ff0000] transition-colors">
              <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8,5.14V19.14L19,12.14L8,5.14Z"/></svg>
           </div>
        </div>
        <div id="video-duration" class="absolute bottom-3 right-3 bg-black/80 text-white text-xs font-bold px-1.5 py-0.5 rounded"></div>
      </div>
      
      <!-- Video Info -->
      <div class="mt-4 px-2 xl:px-0">
        <h1 id="video-title" class="text-[20px] font-bold text-[#f1f1f1] leading-tight line-clamp-2"></h1>
        
        <div class="flex flex-col md:flex-row md:items-center justify-between mt-3 gap-4">
          
          <!-- Channel Info Dummy -->
          <div class="flex items-center gap-3">
             <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-purple-600 to-blue-500 flex items-center justify-center text-lg font-bold text-white shadow-sm">Y</div>
             <div class="flex flex-col justify-center leading-snug">
               <h3 class="font-bold text-[#f1f1f1] text-[16px]">YouTubeDL Content</h3>
               <p class="text-[#aaaaaa] text-[12px]">2.4M subscribers</p>
             </div>
             <button class="bg-[#f1f1f1] text-[#0f0f0f] font-medium text-sm px-4 h-9 rounded-full ml-3 hover:bg-[#d9d9d9] transition-colors">Subscribe</button>
          </div>

          <!-- Action Row mimicking YT buttons -->
          <div class="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0 scrollbar-hide">
             <div class="flex items-center bg-[#272727] rounded-full h-9 shadow-sm">
                <select id="format-select" class="bg-transparent text-sm font-medium text-[#f1f1f1] pl-4 pr-2 h-full focus:outline-none appearance-none cursor-pointer border-r border-[#3f3f3f]">
                  <option value="mp4" class="bg-[#272727]">Video (MP4)</option>
                  <option value="mp3" class="bg-[#272727]">Audio (MP3)</option>
                </select>
                <select id="res-select" class="bg-transparent text-sm font-medium text-[#f1f1f1] pl-2 pr-4 h-full focus:outline-none appearance-none cursor-pointer">
                  <option value="2160" class="bg-[#272727]">4K</option>
                  <option value="1440" class="bg-[#272727]">1440p</option>
                  <option value="1080" selected class="bg-[#272727]">1080p</option>
                  <option value="720" class="bg-[#272727]">720p</option>
                  <option value="480" class="bg-[#272727]">480p</option>
                  <option value="360" class="bg-[#272727]">360p</option>
                </select>
             </div>

             <button id="download-btn" class="flex items-center gap-2 bg-[#272727] hover:bg-[#3f3f3f] px-4 h-9 rounded-full text-sm font-medium transition-colors shadow-sm">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17,18v1H6v-1H17z M16.5,9l-1.4-1.5L12,10.6V3h-2v7.6L6.9,7.5L5.5,9l6,6L16.5,9z"/></svg>
                Download
             </button>
          </div>
        </div>
        
        <!-- Description box mimic -->
        <div class="mt-4 bg-[#272727] rounded-xl p-3 text-sm hover:bg-[#3f3f3f] transition-colors cursor-pointer">
           <div class="font-bold text-[#f1f1f1] mb-1">1.2M views  &bull;  Premiered today</div>
           <p class="text-[#f1f1f1]">Get your video in high quality format instantly. <br>Our backend will merge 4K video and audio directly for you.</p>
           <p class="text-[#aaaaaa] mt-2 font-medium">Show less</p>
        </div>
      </div>
    </div>

    <!-- Sidebar recommendations dummy -->
    <div class="w-full xl:w-[400px] flex flex-col gap-3 px-2 xl:px-0 mt-6 xl:mt-0">
        <div class="flex gap-2 group cursor-pointer mb-2">
           <div class="w-[168px] h-[94px] bg-[#272727] rounded-xl flex-shrink-0 relative overflow-hidden group-hover:opacity-80 transition-opacity">
              <div class="absolute inset-0 flex items-center justify-center">
                 <svg class="w-8 h-8 text-[#aaaaaa]" fill="currentColor" viewBox="0 0 24 24"><path d="M8,5.14V19.14L19,12.14L8,5.14Z"/></svg>
              </div>
              <div class="absolute bottom-1 right-1 bg-black text-white text-xs px-1 font-bold rounded">10:01</div>
           </div>
           <div class="flex flex-col py-1">
              <h4 class="text-[#f1f1f1] font-medium text-[14px] leading-tight line-clamp-2">How to download in 4K resolution using YouTubeDL</h4>
              <p class="text-[#aaaaaa] text-[12px] mt-1 hover:text-[#f1f1f1]">YouTubeDL Docs</p>
              <p class="text-[#aaaaaa] text-[12px]">2.1M views &bull; 2 days ago</p>
           </div>
        </div>
        <div class="flex gap-2 group cursor-pointer mb-2">
           <div class="w-[168px] h-[94px] bg-[#272727] rounded-xl flex-shrink-0 relative overflow-hidden group-hover:opacity-80 transition-opacity">
              <div class="absolute inset-0 flex items-center justify-center">
                 <svg class="w-8 h-8 text-[#aaaaaa]" fill="currentColor" viewBox="0 0 24 24"><path d="M8,5.14V19.14L19,12.14L8,5.14Z"/></svg>
              </div>
              <div class="absolute bottom-1 right-1 bg-black text-white text-xs px-1 font-bold rounded">05:22</div>
           </div>
           <div class="flex flex-col py-1">
              <h4 class="text-[#f1f1f1] font-medium text-[14px] leading-tight line-clamp-2">Download YouTube videos as MP3 fast</h4>
              <p class="text-[#aaaaaa] text-[12px] mt-1 hover:text-[#f1f1f1]">YouTubeDL Docs</p>
              <p class="text-[#aaaaaa] text-[12px]">800K views &bull; 1 week ago</p>
           </div>
        </div>
        <div class="flex gap-2 group cursor-pointer mb-2">
           <div class="w-[168px] h-[94px] bg-[#272727] rounded-xl flex-shrink-0 relative overflow-hidden group-hover:opacity-80 transition-opacity">
              <div class="absolute inset-0 flex items-center justify-center">
                 <svg class="w-8 h-8 text-[#aaaaaa]" fill="currentColor" viewBox="0 0 24 24"><path d="M8,5.14V19.14L19,12.14L8,5.14Z"/></svg>
              </div>
              <div class="absolute bottom-1 right-1 bg-black text-white text-xs px-1 font-bold rounded">12:34</div>
           </div>
           <div class="flex flex-col py-1">
              <h4 class="text-[#f1f1f1] font-medium text-[14px] leading-tight line-clamp-2">Is YouTubeDL safe and secure to use?</h4>
              <p class="text-[#aaaaaa] text-[12px] mt-1 hover:text-[#f1f1f1]">Security Review</p>
              <p class="text-[#aaaaaa] text-[12px]">1.5M views &bull; 1 month ago</p>
           </div>
        </div>
        <div class="flex gap-2 group cursor-pointer mb-2">
           <div class="w-[168px] h-[94px] bg-[#272727] rounded-xl flex-shrink-0 relative overflow-hidden group-hover:opacity-80 transition-opacity">
              <div class="absolute inset-0 flex items-center justify-center">
                 <svg class="w-8 h-8 text-[#aaaaaa]" fill="currentColor" viewBox="0 0 24 24"><path d="M8,5.14V19.14L19,12.14L8,5.14Z"/></svg>
              </div>
              <div class="absolute bottom-1 right-1 bg-black text-white text-xs px-1 font-bold rounded">08:15</div>
           </div>
           <div class="flex flex-col py-1">
              <h4 class="text-[#f1f1f1] font-medium text-[14px] leading-tight line-clamp-2">Best practices for offline viewing</h4>
              <p class="text-[#aaaaaa] text-[12px] mt-1 hover:text-[#f1f1f1]">Tech Guide</p>
              <p class="text-[#aaaaaa] text-[12px]">500K views &bull; 3 months ago</p>
           </div>
        </div>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById('dl-form') as HTMLFormElement;
  const urlInput = document.getElementById('url-input') as HTMLInputElement;
  const fetchBtn = document.getElementById('fetch-btn') as HTMLButtonElement;
  const fetchIcon = document.getElementById('fetch-icon');
  const fetchSpinner = document.getElementById('fetch-spinner');
  
  const errorMsg = document.getElementById('error-message');
  const previewCard = document.getElementById('preview-card');
  const videoThumb = document.getElementById('video-thumb') as HTMLImageElement;
  const videoTitle = document.getElementById('video-title');
  const videoDuration = document.getElementById('video-duration');
  
  const formatSelect = document.getElementById('format-select') as HTMLSelectElement;
  const resSelect = document.getElementById('res-select') as HTMLSelectElement;
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;

  let currentVideoUrl = '';
  let currentVideoTitle = '';

  const setLoading = (isLoading: boolean) => {
    fetchBtn.disabled = isLoading;
    urlInput.disabled = isLoading;
    if (isLoading) {
      fetchIcon?.classList.add('hidden');
      fetchSpinner?.classList.remove('hidden');
    } else {
      fetchIcon?.classList.remove('hidden');
      fetchSpinner?.classList.add('hidden');
    }
  };

  const showError = (msg: string) => {
    if (errorMsg) {
      errorMsg.textContent = msg;
      errorMsg.classList.remove('hidden');
    }
  };

  const hideError = () => {
    errorMsg?.classList.add('hidden');
  };

  const showPreview = (data: any) => {
    currentVideoUrl = urlInput.value;
    currentVideoTitle = data.title;
    
    if (videoThumb) videoThumb.src = data.thumbnail;
    if (videoTitle) videoTitle.textContent = data.title;
    if (videoDuration) videoDuration.textContent = data.duration || 'Live';
    
    // Check available formats and disable resolutions not available
    const availableHeights = data.formats.map((f:any) => f.height).filter(Boolean);
    const maxHeight = Math.max(...availableHeights, 360);
    
    Array.from(resSelect.options).forEach(opt => {
      opt.disabled = parseInt(opt.value) > maxHeight;
      if(opt.disabled) {
         opt.classList.add('text-[#777777]');
      } else {
         opt.classList.remove('text-[#777777]');
      }
    });
    
    // Select the highest available by default up to 1080p
    let defaultRes = "1080";
    if (maxHeight < 1080) defaultRes = String(maxHeight);
    
    const validDefault = Array.from(resSelect.options).find(o => !o.disabled && o.value <= defaultRes);
    if (validDefault) resSelect.value = validDefault.value;

    previewCard?.classList.remove('hidden');
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const url = urlInput.value.trim();
    if (!url) return;

    hideError();
    setLoading(true);
    previewCard?.classList.add('hidden');

    try {
      const res = await fetch('/api/info', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url })
      });
      const data = await res.json();

      if (!res.ok) throw new Error(data.error || 'Failed to fetch video info');
      showPreview(data);
    } catch (err: any) {
      showError(err.message);
    } finally {
      setLoading(false);
    }
  });

  formatSelect?.addEventListener('change', () => {
    if (formatSelect.value === 'mp3') {
      resSelect.classList.add('opacity-50', 'pointer-events-none');
    } else {
      resSelect.classList.remove('opacity-50', 'pointer-events-none');
    }
  });

  downloadBtn?.addEventListener('click', () => {
    const type = formatSelect.value;
    const res = resSelect.value;
    const url = encodeURIComponent(currentVideoUrl);
    const title = encodeURIComponent(currentVideoTitle);
    
    window.location.href = `/api/download?url=${url}&type=${type}&res=${res}&title=${title}`;
  });

  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement && e.target !== urlInput) return;
    if (e.target instanceof HTMLTextAreaElement) return;
    
    if (e.key.toLowerCase() === 'c' && document.activeElement !== urlInput) {
      e.preventDefault();
      urlInput.value = '';
      urlInput.focus();
      hideError();
      previewCard?.classList.add('hidden');
    }
  });
</script>
