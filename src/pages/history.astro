---
import Layout from '../layouts/Layout.astro';
---

<Layout title="History - NexDL">
  <div class="w-full flex flex-col items-center justify-center pt-20">
    <div class="w-20 h-20 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-6">
      <svg class="w-10 h-10 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    </div>
    <h2 class="text-2xl font-bold text-white mb-2">Download History</h2>
    <p class="text-zinc-400">Your recent downloads will appear here.</p>
  </div>
</Layout>
