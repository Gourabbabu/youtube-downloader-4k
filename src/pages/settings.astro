---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Settings - NexDL">
  <div class="w-full max-w-3xl mx-auto pt-10 px-4">
    <div class="flex items-center gap-4 mb-8">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
      </div>
      <h2 class="text-3xl font-bold text-white">Settings</h2>
    </div>

    <div class="glass-card rounded-[24px] p-6 sm:p-8 space-y-8">
      
      <!-- Download Folder -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-6">
        <div>
          <h3 class="text-lg font-semibold text-zinc-100">Default Download Folder</h3>
          <p class="text-sm text-zinc-400">Choose where your files are saved.</p>
        </div>
        <button class="bg-white/5 hover:bg-white/10 border border-white/10 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
          Browse...
        </button>
      </div>

      <!-- Preferred Quality -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-6">
        <div>
          <h3 class="text-lg font-semibold text-zinc-100">Preferred Video Quality</h3>
          <p class="text-sm text-zinc-400">Default quality when downloading via quick actions.</p>
        </div>
        <select class="bg-zinc-900 border border-white/10 text-white px-4 py-2 rounded-lg text-sm font-medium outline-none focus:border-indigo-500">
          <option>4K (2160p)</option>
          <option selected>HD (1080p)</option>
          <option>HD (720p)</option>
          <option>SD (480p)</option>
        </select>
      </div>

      <!-- Theme Switcher -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-6">
        <div>
          <h3 class="text-lg font-semibold text-zinc-100">Appearance</h3>
          <p class="text-sm text-zinc-400">Select your preferred theme.</p>
        </div>
        <div class="flex bg-zinc-900 border border-white/10 rounded-lg p-1">
          <button class="px-4 py-1.5 rounded-md text-sm font-medium text-zinc-400 hover:text-white transition-colors">Light</button>
          <button class="px-4 py-1.5 rounded-md text-sm font-medium bg-zinc-800 text-white shadow-sm transition-colors">Dark</button>
          <button class="px-4 py-1.5 rounded-md text-sm font-medium text-zinc-400 hover:text-white transition-colors">System</button>
        </div>
      </div>

      <!-- Notifications -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h3 class="text-lg font-semibold text-zinc-100">Download Notifications</h3>
          <p class="text-sm text-zinc-400">Get notified when a download completes.</p>
        </div>
        <button class="w-12 h-6 rounded-full bg-indigo-500 relative transition-colors focus:outline-none">
          <span class="absolute right-1 top-1 w-4 h-4 bg-white rounded-full transition-transform"></span>
        </button>
      </div>

    </div>
  </div>
</Layout>
