---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Batch Downloads - NexDL">
  <div class="w-full flex flex-col items-center justify-center pt-20">
    <div class="w-20 h-20 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-6">
      <svg class="w-10 h-10 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
    </div>
    <h2 class="text-2xl font-bold text-white mb-2">Batch Downloads</h2>
    <p class="text-zinc-400 mb-8 max-w-md text-center">Paste multiple URLs to download them all at once. Pro feature coming soon.</p>
    <div class="glass-card w-full max-w-2xl rounded-2xl p-4">
      <textarea class="w-full h-32 bg-zinc-900/50 text-white placeholder-zinc-500 rounded-xl p-4 border border-white/10 outline-none focus:border-indigo-500" placeholder="Paste YouTube URLs here (one per line)..."></textarea>
      <div class="mt-4 flex justify-end">
        <button class="bg-indigo-500/50 text-white px-6 py-2.5 rounded-xl font-medium cursor-not-allowed opacity-50">Start Batch</button>
      </div>
    </div>
  </div>
</Layout>
